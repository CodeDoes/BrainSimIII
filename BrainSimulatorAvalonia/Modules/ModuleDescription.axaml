<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="BrainSimulatorAvalonia.Modules.ModuleDescriptionDlg"
        Width="1200" Height="800"
        Title="Description"
        Background="LightGray">
    <Grid>
        <TextBox Name="Description" VerticalScrollBarVisibility="Auto" Margin="20,49,38,99" TextWrapping="Wrap" AcceptsReturn="True" Background="LightBlue"/>
        <Button Name="buttonSave" Content="Save" Margin="0,0,154,27" Width="100" Height="34" VerticalAlignment="Bottom" HorizontalAlignment="Right" ToolTip.Tip="Saves the edited text, but does not close the dialog."/>
        <Button Name="buttonClose" Content="Close" Margin="0,0,38,27" Width="100" Height="34" VerticalAlignment="Bottom" HorizontalAlignment="Right" ToolTip.Tip="Closes the dialog, without saving any changes."/>
        <TextBlock Text="Description:" HorizontalAlignment="Left" Margin="20,28,0,0" VerticalAlignment="Top"/>
        <ComboBox Name="moduleSelector" HorizontalAlignment="Left" Margin="368,10,0,0" VerticalAlignment="Top" Width="120"/>
        <TextBlock HorizontalAlignment="Left" Margin="248,10,0,0" TextWrapping="Wrap" Text="Select Module Type:" VerticalAlignment="Top" />
    </Grid>
</Window>