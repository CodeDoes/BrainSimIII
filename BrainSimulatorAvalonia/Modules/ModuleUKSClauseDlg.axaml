<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="BrainSimulatorAvalonia.Modules.ModuleUKSClauseDlg">
  <Grid Margin="0">
    <Label Name="sourceeLabel" Content="Source" HorizontalAlignment="Left" Height="33" Margin="56,43,0,0" FontSize="16" Width="68" VerticalAlignment="Top"/>
    <Label Name="relationshipTypeLabel" Content="Type" HorizontalAlignment="Left" Height="33" Margin="56,83,0,0" FontSize="16" Width="68" VerticalAlignment="Top"/>
    <Label Name="targetLabel" Content="Target" HorizontalAlignment="Left" Height="33" Margin="56,123,0,0" FontSize="16" Width="68" VerticalAlignment="Top"/>

    <TextBox Name="sourceText" TabIndex="1" Height="33" VerticalAlignment="Top" FontSize="16" Margin="124,43,156,0"/>
    <TextBox Name="relationshipText" TabIndex="2" Height="33" VerticalAlignment="Top" FontSize="16" Margin="124,83,156,0"/>
    <TextBox Name="targetText" TabIndex="3" Height="33" VerticalAlignment="Top" FontSize="16" Margin="124,123,156,0"/>

    <Button Name="BtnAddRelationship" Content="Add/Update" Height="32" VerticalAlignment="Top" FontSize="16" Margin="124,378,0,0" HorizontalAlignment="Left" Width="158"/>

    <Label Content="Clause Type" HorizontalAlignment="Left" Height="33" Margin="56,178,0,0" FontSize="16" Width="98" VerticalAlignment="Top"/>
    <Label Content="Source" HorizontalAlignment="Left" Height="33" Margin="56,248,0,0" FontSize="16" Width="68" VerticalAlignment="Top"/>
    <Label Content="Type" HorizontalAlignment="Left" Height="33" Margin="56,288,0,0" FontSize="16" Width="68" VerticalAlignment="Top"/>
    <Label Content="Target" HorizontalAlignment="Left" Height="33" Margin="56,328,0,0" FontSize="16" Width="68" VerticalAlignment="Top"/>

    <TextBox Name="clauseTypeText" TabIndex="4" Height="33" VerticalAlignment="Top" FontSize="16" Margin="156,178,156,0"/>
    <TextBox Name="sourceText2" TabIndex="5" Height="33" VerticalAlignment="Top" FontSize="16" Margin="124,248,156,0"/>
    <TextBox Name="relationshipText2" TabIndex="6" Height="33" VerticalAlignment="Top" FontSize="16" Margin="124,288,156,0"/>
    <TextBox Name="targetText2" TabIndex="7" Height="33" VerticalAlignment="Top" FontSize="16" Margin="124,328,156,0"/>

    <Label Content="Condition" FontSize="18" HorizontalAlignment="Left" Height="31" Margin="150,212,0,0" VerticalAlignment="Top" Width="224"/>
    <Label Content="Relationship" FontSize="18" HorizontalAlignment="Left" Height="30" Margin="146,0,0,0" VerticalAlignment="Top" Width="224"/>
    <ComboBox Name="SourceDisambiguation" FontSize="18" IsVisible="False" HorizontalAlignment="Left" Margin="284,0,0,0" VerticalAlignment="Top" Width="120" Height="34"/>
  </Grid>
</UserControl>