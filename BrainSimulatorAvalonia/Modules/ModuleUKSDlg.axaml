<!-- BrainSimulatorAvalonia/Modules/ModuleUKSDlg.axaml -->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="BrainSimulatorAvalonia.Modules.ModuleUKSDlg">
    <Grid>
        <TreeView Name="theTreeView" FontSize="16"
                  Background="LightGray" Foreground="Black" Margin="0,68,0,40" />
        <CheckBox Name="detailsCB" Content="Show Details" HorizontalAlignment="Left" Margin="131,10,0,0" Width="120" FontSize="16" Height="19" VerticalAlignment="Top"/>
        <CheckBox Name="checkBoxAuto" IsChecked="True" Content="Auto-Refresh" HorizontalAlignment="Left" Margin="131,39,0,0" Width="120" FontSize="16" Height="19" VerticalAlignment="Top"/>
        <CheckBox Name="reverseCB" IsChecked="False" Content="Reverse Rels." HorizontalAlignment="Left" Margin="256,10,0,0" Width="161" FontSize="16" Height="19" VerticalAlignment="Top"/>
        <CheckBox Name="showConditionals" IsChecked="False" Content="Show Conditionals" HorizontalAlignment="Left" Margin="256,39,0,0" Width="161" FontSize="16" Height="19" VerticalAlignment="Top"/>
        <Label Content="Root:" HorizontalAlignment="Left" Margin="424,4,0,0" Width="90" FontSize="16" Height="35" VerticalAlignment="Top"/>
        <TextBox Name="textBoxRoot" HorizontalAlignment="Left" Margin="467,8,0,0" TextWrapping="Wrap" Text="Thing" Width="150" FontSize="16" Height="25" VerticalAlignment="Top"/>
        <Label Name="statusLabel"  HorizontalAlignment="Left" Margin="424,33,0,0" Width="193" FontSize="16" Height="35" VerticalAlignment="Top"/>
        <Button Name="InitializeButton" Content="Initialize" VerticalAlignment="Top" Height="25" Margin="18,19,0,0" FontSize="16" HorizontalAlignment="Left" Width="90"/>
        <Button Content="Import" Height="25" HorizontalAlignment="Left" Margin="628,8,0,0" VerticalAlignment="Top" FontSize="16" Width="70"/>
        <Button Content="Export" Height="25"  HorizontalAlignment="Left" Margin="628,39,0,0" VerticalAlignment="Top" FontSize="16" Width="70"/>
    </Grid>
</UserControl>
